#!/bin/sh

cd ~

# Check if ~/.config/chadwm exists
if [ ! -d "$HOME/.config/chadwm" ]; then
    echo "Directory ~/.config/chadwm does not exist. Copying from /etc/skel/.config/chadwm..."

    # Ensure the target directory exists
    mkdir -p "$HOME/.config"

    # Copy the contents from /etc/skel/.config/chadwm to ~/.config/chadwm
    cp -r /etc/skel/.config/chadwm "$HOME/.config/chadwm"

else
    echo "Directory ~/.config/chadwm already exists. Skipping copy."
fi

# Run the script
~/.config/chadwm/scripts/run.sh
